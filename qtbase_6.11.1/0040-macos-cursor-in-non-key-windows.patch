diff --git a/src/plugins/platforms/cocoa/qnsview_mouse.mm b/src/plugins/platforms/cocoa/qnsview_mouse.mm
--- a/src/plugins/platforms/cocoa/qnsview_mouse.mm
+++ b/src/plugins/platforms/cocoa/qnsview_mouse.mm
@@ -507,6 +507,22 @@
 
     if (NSCursor.currentCursor != previousCursor)
         qCInfo(lcQpaMouse) << "Cursor update for" << self << "resulted in new cursor" << NSCursor.currentCursor;
+}
+
+- (void)applyCursorIfNotKeyWindow
+{
+    // AppKit only delivers cursorUpdate: to key windows (and to utility windows),
+    // so a window that is not key would keep whatever cursor happened to be current
+    // when the mouse entered it. We apply the cursor ourselves in that case, from
+    // mouse enter and mouse move, which is where AppKit would have serviced the
+    // cursor rects of our tracking area for a key window.
+    if (!NSApp.active || self.window.keyWindow || !self.cursor)
+        return;
+
+    if (NSCursor.currentCursor != self.cursor) {
+        qCInfo(lcQpaMouse) << "Applying" << self.cursor << "for non-key" << self;
+        [self.cursor set];
+    }
 }
 
