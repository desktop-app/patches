+/*!
+    \internal
+
+    Allows or refuses NTLM/Negotiate proxy authentication for the whole
+    application. It is refused by default, because a malicious proxy can use it
+    to silently relay the user's Windows domain credentials. It should only be
+    allowed when the proxy comes from the system configuration.
+*/
+void QNetworkProxy::setProxyAuthenticationNtlmAllowed(bool allowed)
+{
+    QAuthenticatorPrivate::setProxyNtlmAuthAllowed(allowed);
+}
+
+/*!
+    \internal
+
+    Returns whether NTLM/Negotiate proxy authentication is currently allowed.
+
+    \sa setProxyAuthenticationNtlmAllowed()
+*/
+bool QNetworkProxy::proxyAuthenticationNtlmAllowed()
+{
+    return QAuthenticatorPrivate::proxyNtlmAuthAllowed();
+}
