+/*!
+    \internal
+
+    Marks this proxy as permitted to use NTLM/Negotiate proxy authentication.
+    It is refused by default, because a malicious proxy can use it to silently
+    relay the user's Windows domain credentials. It is only set for HTTP proxies
+    that come from the system configuration; a proxy configured inside the
+    application is never trusted with it.
+*/
+void QNetworkProxy::setNtlmAuthenticationAllowed(bool allowed)
+{
+    d->ntlmAuthAllowed = allowed;
+}
+
+/*!
+    \internal
+
+    Returns whether NTLM/Negotiate proxy authentication is permitted for this
+    proxy.
+
+    \sa setNtlmAuthenticationAllowed()
+*/
+bool QNetworkProxy::isNtlmAuthenticationAllowed() const
+{
+    return d && d->ntlmAuthAllowed;
+}
+
