diff --git a/src/widgets/kernel/qwidgetrepaintmanager.cpp b/src/widgets/kernel/qwidgetrepaintmanager.cpp
index 90df68d4f9b..5c58722866e 100644
--- a/src/widgets/kernel/qwidgetrepaintmanager.cpp
+++ b/src/widgets/kernel/qwidgetrepaintmanager.cpp
@@ -360,6 +360,21 @@ void QWidgetRepaintManager::sendUpdateRequest(QWidget *widget, UpdateTime update
         // normal backingstore sync machinery.
         if (!widget->d_func()->shouldPaintOnScreen())
             updateRequestSent = true;
+#ifdef Q_OS_MACOS
+        // Pace backingstore updates by the platform update request
+        // mechanism (CVDisplayLink), so that frame production is
+        // phase-locked to the display. A posted event ticks on the
+        // event loop's own schedule instead, beating against the
+        // display clock, and the Metal drawable acquisition then
+        // blocks the main thread whenever the pool has not been
+        // replenished yet.
+        if (widget == tlw && !widget->d_func()->shouldPaintOnScreen()) {
+            if (QWindow *window = widget->windowHandle(); window && window->handle()) {
+                window->requestUpdate();
+                break;
+            }
+        }
+#endif
         QCoreApplication::postEvent(widget, new QEvent(QEvent::UpdateRequest), Qt::LowEventPriority);
         break;
     case UpdateNow: {
diff --git a/src/widgets/kernel/qwidgetwindow.cpp b/src/widgets/kernel/qwidgetwindow.cpp
