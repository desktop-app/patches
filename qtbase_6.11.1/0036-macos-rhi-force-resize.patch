+void QCocoaWindow::syncContentLayerGeometry() const
+{
+    if (auto *containerLayer = qt_objc_cast<QContainerLayer*>(m_view.layer)) {
+        const auto windowSize = window()->size();
+        const auto fallbackBounds = m_view.bounds;
+        const auto width = windowSize.isEmpty() ? fallbackBounds.size.width : windowSize.width();
+        const auto height = windowSize.isEmpty() ? fallbackBounds.size.height : windowSize.height();
+        const auto frame = CGRectMake(0, 0, width, height);
+        auto *contentLayer = containerLayer.contentLayer;
+        if (!CGRectEqualToRect(contentLayer.frame, frame)) {
+            [CATransaction begin];
+            [CATransaction setDisableActions:YES];
+            contentLayer.frame = frame;
+            [CATransaction commit];
+        }
+    }
+}
+
 CALayer *QCocoaWindow::contentLayer() const
 {
+    syncContentLayerGeometry();
+
     auto *layer = m_view.layer;
     if (auto *containerLayer = qt_objc_cast<QContainerLayer*>(layer))
         layer = containerLayer.contentLayer;
