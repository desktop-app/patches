+static inline bool usesWindowSizeForSurfacePixelSize(QWindow *window)
+{
+#ifdef Q_OS_MACOS
+    return window && window->inherits("QWidgetWindow");
+#else
+    Q_UNUSED(window);
+    return false;
+#endif
+}
+
+static inline QSize surfacePixelSizeForLayer(CAMetalLayer *layer, QWindow *window)
+{
+    if (usesWindowSizeForSurfacePixelSize(window)) {
+        const auto windowSize = window->size() * window->devicePixelRatio();
+        if (!windowSize.isEmpty())
+            return windowSize;
+    }
+
+    int height = (int)layer.bounds.size.height;
+    int width = (int)layer.bounds.size.width;
+    width *= layer.contentsScale;
+    height *= layer.contentsScale;
+    return QSize(width, height);
+}
