+void QCALayerBackingStore::GraphicsBuffer::resetRhiTexture(bool unregisterCallback)
+{
+    if (unregisterCallback && m_rhi)
+        m_rhi->removeCleanupCallback(this);
+
+    m_rhiTexture.reset();
+#if QT_CONFIG(metal)
+    if (m_metalTexture) {
+        [(id<MTLTexture>)m_metalTexture release];
+        m_metalTexture = nullptr;
+    }
+#else
+    m_metalTexture = nullptr;
+#endif
+    m_rhi = nullptr;
+}
+
+QRhiTexture *QCALayerBackingStore::GraphicsBuffer::rhiTexture(QRhi *rhi)
+{
+#if QT_CONFIG(metal)
+    if (!rhi || rhi->backend() != QRhi::Metal)
+        return nullptr;
+
+    if (m_rhi != rhi)
+        resetRhiTexture();
+
+    if (m_rhiTexture)
+        return m_rhiTexture.get();
+
+    const auto *handles = static_cast<const QRhiMetalNativeHandles *>(rhi->nativeHandles());
+    if (!handles || !handles->dev)
+        return nullptr;
+
+    auto *desc = [[MTLTextureDescriptor alloc] init];
+    desc.textureType = MTLTextureType2D;
+    desc.pixelFormat = MTLPixelFormatBGRA8Unorm;
+    desc.width = NSUInteger(size().width());
+    desc.height = NSUInteger(size().height());
+    desc.mipmapLevelCount = 1;
+    desc.sampleCount = 1;
+    desc.usage = MTLTextureUsageShaderRead;
+
+    id<MTLDevice> device = (id<MTLDevice>)handles->dev;
+    id<MTLTexture> texture = [device newTextureWithDescriptor:desc iosurface:surface() plane:0];
+    [desc release];
+    if (!texture)
+        return nullptr;
+
+    m_rhiTexture.reset(rhi->newTexture(QRhiTexture::BGRA8, size()));
+    if (!m_rhiTexture) {
+        [texture release];
+        return nullptr;
+    }
+
+    const auto nativeTexture = QRhiTexture::NativeTexture{ quint64(quintptr(texture)), 0 };
+    if (!m_rhiTexture->createFrom(nativeTexture)) {
+        [texture release];
+        m_rhiTexture.reset();
+        return nullptr;
+    }
+
+    m_rhi = rhi;
+    m_metalTexture = texture;
+    m_rhi->addCleanupCallback(this, [this](QRhi *) {
+        resetRhiTexture(false);
+    });
+    return m_rhiTexture.get();
+#else
+    Q_UNUSED(rhi);
+    return nullptr;
+#endif
+}
+
+bool QCALayerBackingStore::GraphicsBuffer::beginRhiUse(QRhiCommandBuffer *commandBuffer)
+{
+#if QT_CONFIG(metal)
+    if (!commandBuffer || !m_metalTexture)
+        return false;
+
+    const auto *handles = static_cast<const QRhiMetalCommandBufferNativeHandles *>(commandBuffer->nativeHandles());
+    if (!handles || !handles->commandBuffer)
+        return false;
+
+    auto surfaceRef = surface();
+    CFRetain(surfaceRef);
+    IOSurfaceIncrementUseCount(surfaceRef);
+
+    id<MTLTexture> texture = [(id<MTLTexture>)m_metalTexture retain];
+    id<MTLCommandBuffer> metalCommandBuffer = (id<MTLCommandBuffer>)handles->commandBuffer;
+    [metalCommandBuffer addCompletedHandler:^(id<MTLCommandBuffer>) {
+        IOSurfaceDecrementUseCount(surfaceRef);
+        CFRelease(surfaceRef);
+        [texture release];
+    }];
+    return true;
+#else
+    Q_UNUSED(commandBuffer);
+    return false;
+#endif
+}
