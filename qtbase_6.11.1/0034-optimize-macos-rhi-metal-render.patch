+QRhiTexture *QCALayerBackingStore::toNativeTexture(QRhi *rhi,
+                                                   QRhiResourceUpdateBatch *resourceUpdates,
+                                                   const QRegion &dirtyRegion,
+                                                   TextureFlags *flags) const
+{
+    Q_UNUSED(resourceUpdates);
+    Q_UNUSED(dirtyRegion);
+
+#if QT_CONFIG(metal)
+    if (!rhi || rhi->backend() != QRhi::Metal || !m_buffers.back()
+        || window()->format().swapBehavior() == QSurfaceFormat::SingleBuffer) {
+        return nullptr;
+    }
+
+    QRhiTexture *texture = m_buffers.back()->rhiTexture(rhi);
+    if (!texture)
+        return nullptr;
+
+    *flags = TexturePremultiplied;
+    m_rhiCompositedBuffer = m_buffers.back().get();
+    return texture;
+#else
+    Q_UNUSED(rhi);
+    Q_UNUSED(flags);
+    return nullptr;
+#endif
+}
+
+void QCALayerBackingStore::nativeTextureWasComposited(QRhiCommandBuffer *commandBuffer)
+{
+#if QT_CONFIG(metal)
+    GraphicsBuffer *buffer = m_rhiCompositedBuffer;
+    m_rhiCompositedBuffer = nullptr;
+    if (!buffer || !buffer->beginRhiUse(commandBuffer))
+        return;
+
+    if (buffer == m_buffers.back().get() && m_buffers.back() != m_buffers.front())
+        std::swap(m_buffers.back(), m_buffers.front());
+#else
+    Q_UNUSED(commandBuffer);
+#endif
+}
