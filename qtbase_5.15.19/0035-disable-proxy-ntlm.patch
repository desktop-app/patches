+static bool qStartsWithAuthenticationScheme(const QByteArray &value, const char *scheme)
+{
+    const QByteArray trimmed = value.trimmed();
+    const int schemeSize = int(qstrlen(scheme));
+    if (trimmed.size() < schemeSize)
+        return false;
+    if (trimmed.left(schemeSize).compare(scheme, Qt::CaseInsensitive) != 0)
+        return false;
+    if (trimmed.size() == schemeSize)
+        return true;
+    const char separator = trimmed.at(schemeSize);
+    return separator == ' ' || separator == '\t' || separator == ',';
+}
+
+static bool qIsUnsafeProxyAuthenticationScheme(const QByteArray &value)
+{
+    if (QAuthenticatorPrivate::proxyNtlmAuthAllowed())
+        return false;
+    return qStartsWithAuthenticationScheme(value, "ntlm")
+        || qStartsWithAuthenticationScheme(value, "negotiate");
+}
+
+// When false (the default), NTLM/Negotiate proxy authentication is refused,
+// because a malicious proxy can use it to silently relay the user's Windows
+// domain credentials. Telegram enables it only when the proxy comes from the
+// system configuration, where such a setup is the responsibility of the OS.
+static QBasicAtomicInt qProxyNtlmAuthAllowed = Q_BASIC_ATOMIC_INITIALIZER(0);
+
+bool QAuthenticatorPrivate::proxyNtlmAuthAllowed()
+{
+    return qProxyNtlmAuthAllowed.loadRelaxed() != 0;
+}
+
+void QAuthenticatorPrivate::setProxyNtlmAuthAllowed(bool allowed)
+{
+    qProxyNtlmAuthAllowed.storeRelaxed(allowed ? 1 : 0);
+}
