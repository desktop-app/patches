+static void advanceAngleDisplayKey(bool force = false)
+{
+    const auto now = QDateTime::currentMSecsSinceEpoch();
+    const auto last = angleDisplayKeyAdvancedAt.loadAcquire();
+    if (!force && last >= 0 && now - last < kAngleDisplayKeyAdvanceInterval)
+        return;
