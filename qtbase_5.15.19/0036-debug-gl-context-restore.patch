         || error == EGL_NOT_INITIALIZED;
 }
 
+static bool shouldRetireAfterCreationFailure(EGLint error)
+{
+    return error == EGL_CONTEXT_LOST
+        || error == EGL_BAD_DISPLAY
+        || error == EGL_NOT_INITIALIZED;
+}
+
 #if !defined(QT_STATIC) || defined(QT_OPENGL_DYNAMIC)
 
 #ifdef Q_CC_MINGW
@@ -403,6 +410,14 @@ void QWindowsEGLStaticContext::markLost(EGLint error)
         terminate();
 }
 
+void QWindowsEGLStaticContext::markCreationFailure(EGLint error)
+{
+    if (!shouldRetireAfterCreationFailure(error))
+        return;
+
+    markLost(error);
+}
