+
+static void advanceAngleDisplayKey()
+{
+    const auto now = QDateTime::currentMSecsSinceEpoch();
+    const auto last = angleDisplayKeyAdvancedAt.loadAcquire();
+    if (last >= 0 && now - last < kAngleDisplayKeyAdvanceInterval)
+        return;
+
+    if (angleDisplayKeyAdvancedAt.testAndSetRelaxed(last, now)) {
+        const auto previousKey = angleDisplayKey.loadAcquire();
+        qCDebug(lcQpaGl, "QWindowsEGLStaticContext: Advancing ANGLE display key: %d -> %d",
+                previousKey, previousKey + 1);
+        angleDisplayKey.ref();
+    }
+}
+#endif // DESKTOP_APP_QT_STATIC_ANGLE
